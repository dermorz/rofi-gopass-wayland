# Config example (also default values)

# Set alternative gopass store dirs. Use ":" to separate multiple roots.
# Can be switched at runtime with with corresponding hotkeys
# ROOTS=/path/to/root_one:/path/to/root_two

# You can define gopass env vars here and they will be sourced in
# the script and applied to all gopass commands called. Like:
# GOPASS_CLIP_TIME=30
# GOPASS_GENERATED_LENGTH=13

# Same way you can define other env vars that gopass is using:
# EDITOR='vim -x'
# BROWSER= # default: xdg-open

# Fields to be used (space-separated for USERNAME_FIELD to support multiple aliases)
URL_FIELD='url'
USERNAME_FIELD='user username'
AUTOTYPE_FIELD='autotype'

BACK_OPTION='← back'

# delay to be used for :delay keyword
delay=2
# rofi-gopass needs to close itself before it can type passwords. Set delay here.
wait=0.2
# delay between keypresses when typing (in ms)
type_delay=12

## Options for generating new password entries
# open new password entries in editor
edit_new_pass="true"
# set to ':basename' for user field to be set to password basename
default_user="$(whoami)"
# users that you will see as an option to choose when creating new password.
# Space separated.
users_list="some@mail.com another@gmail.com localuser"

# Password generator settings (gopass generate options)
# Generator type: cryptic (default), memorable, xkcd, or external
# Example: generator="xkcd"
# generator="cryptic"     # e.g., "Eech4ahRoy2oowi0ohl" (random chars)
# generator="memorable"   # e.g., "puma-nag2-scout-chute-emu" (readable words)
# generator="xkcd"       # e.g., "correct-horse-battery-staple" (passphrase style)

# Password length (for cryptic generator)
# Default: 20
# gen_length="20"

# Include symbols in password (for cryptic generator)
# Default: true
# gen_symbols="true"

# Number of words (for xkcd/memorable generators)
# Default: 6
# gen_word_count="6"

# Word separator (for xkcd/memorable generators)
# Default: -
# gen_separator="-"

# Language for xkcd/memorable word lists (only en or de supported)
# Default: en
# gen_lang="en"

# Capitalize words (for xkcd/memorable generators)
# Default: true
# gen_capitalize="true"

# Include number (for xkcd/memorable generators)
# Default: true
# gen_number="true"

# Terminal to use when running from rofi (auto-detected if empty)
# Auto-detected in order: alacritty, foot, kitty, wezterm, gnome-terminal, konsole, xterm
# Examples: alacritty, foot, kitty, wezterm, gnome-terminal, konsole
# terminal_editor=""

# Set to "true" if using a GUI editor that needs a terminal anyway
# Default: false
# gui_editor="false"

## Misc settings

default_autotype="user :tab pass"
auto_enter='false'
notify='false'

# default shortcuts
help="Alt+h"

kb_type_field="Alt+t"
kb_type_pass="Alt+p"
kb_type_user="Alt+n"
kb_type_otp="Alt+o"
kb_autotype="Alt+a"

kb_copy_field="Alt+C"
kb_copy_pass="Alt+P"
kb_copy_user="Alt+N"
kb_copy_otp="Alt+O"

kb_insert="Alt+i"
kb_show="Alt+Return"

# Actions
kb_move="Alt+m"
kb_remove="Alt+x"
kb_edit="Alt+e"
kb_generate="Alt+I"

kb_browse_url="Alt+U"
kb_qrcode="Alt+q"
kb_switch_root="Alt+bracketright" # ]

# --- Customisable functions ---

_rofi() { rofi -no-auto-select -i -dmenu "$@"; }

_notify() { notify-send -e "rofi-gopass" "$1"; }

_store_changed_hook() {
	gopass git pull --rebase && gopass git push
}

_generate_pass() { gopass generate --clip --in-place "$@" > /dev/null; }

_get_otp() { gopass otp "$@"; }
